# Public Sentry DSN — exposed to the browser. Safe to commit a placeholder, but the real value lives in Vercel + GitHub secrets.
NEXT_PUBLIC_SENTRY_DSN=

# Server-only Sentry DSN. If empty, falls back to NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=

# Sentry source-map upload (CI only). Leave empty locally.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Postgres connection string for the app. Required at runtime.
# Local dev example: postgres://mente:mente@localhost:5432/mente
DATABASE_URL=

# Postgres connection string used by the integration test. The test wipes
# the `public` schema, so point it at a disposable DB. If unset, the
# integration test is skipped with a clear message.
TEST_DATABASE_URL=
